{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "Flight Delay MLOps — Model Monitoring",
  "uid": "flight-delay-model-monitoring",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Prediction Volume (req/min)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(flight_predictions_total[1m]) * 60",
          "legendFormat": "predictions / min"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Prediction Latency (p50 / p95 / p99)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(flight_prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(flight_prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(flight_prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 3,
      "type": "piechart",
      "title": "Delay Class Ratio (delayed vs on-time)",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "increase(flight_delay_predictions{delay_class=\"delayed\"}[1h])",
          "legendFormat": "Delayed"
        },
        {
          "expr": "increase(flight_delay_predictions{delay_class=\"ontime\"}[1h])",
          "legendFormat": "On-time"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Model Drift Score (mean PSI)",
      "gridPos": { "x": 8, "y": 8, "w": 16, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "flight_model_drift_score",
          "legendFormat": "Drift Score (PSI)"
        }
      ],
      "thresholds": {
        "mode": "absolute",
        "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 0.1 },
          { "color": "red", "value": 0.5 }
        ]
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Rolling Accuracy (R² / MAE) — from feedback",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "flight_rolling_r2",
          "legendFormat": "Rolling R²"
        },
        {
          "expr": "flight_rolling_mae / 60",
          "legendFormat": "Rolling MAE (normalised)"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Error Rate (errors/s)",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(flight_model_errors_total[5m])",
          "legendFormat": "{{ error_type }}"
        }
      ]
    },
    {
      "id": 7,
      "type": "gauge",
      "title": "Data Quality Score",
      "gridPos": { "x": 0, "y": 24, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "flight_data_quality_score", "legendFormat": "Quality" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "minVizValue": 0,
        "maxVizValue": 1
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Total Predictions (24 h)",
      "gridPos": { "x": 6, "y": 24, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "increase(flight_predictions_total[24h])", "legendFormat": "Total" }
      ]
    }
  ]
}
